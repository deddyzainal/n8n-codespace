{
  "name": "n8n Workspace",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "n8n",
  "workspaceFolder": "/home/node/.n8n",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n",
      "onAutoForward": "notify"
    }
  },
  "postStartCommand": "echo '🚀 n8n is ready at http://localhost:5678'"
}
